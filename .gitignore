
# ─── SECRETS (MOST IMPORTANT — NEVER COMMIT) ────────────────
.env
.env.local
.env.production
.env.staging
.env.development.local
.env.test.local
.env.production.local

# Keep example/template files — safe to push (no real secrets)
!.env.example
!.env.local.example


